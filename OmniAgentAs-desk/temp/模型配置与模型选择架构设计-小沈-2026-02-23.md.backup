## 一、现有使用方式分析

### 1.1 前端当前使用方式

**状态管理**（`frontend/src/components/Layout/index.tsx`）：

```typescript
// 当前模型ID，格式: "provider-modelname"
const [_currentModelInfo, setCurrentModelInfo] = useState<string>('opencode-minimax-m2.5-free');

// 模型列表
const [modelList, setModelList] = useState<{id: string; name: string; provider: string}[]>([]);
```

**初始化流程**：

```typescript
// 1. 调用API获取模型列表和配置
const [modelData, config] = await Promise.all([
  configApi.getModelList(),  // 返回 models 数组
  configApi.getConfig()      // 返回 ai_provider, ai_model
]);

// 2. 使用 ai_provider 和 ai_model 匹配正确的模型
if (config.ai_provider && config.ai_model && modelData.models) {
  const currentModel = modelData.models.find(
    m => m.provider === config.ai_provider && 
       m.id.includes(config.ai_model)
  );
  if (currentModel) {
    setCurrentModelInfo(currentModel.id);  // 设置为 "provider-modelname" 格式
  }
}
```

### 1.2 后端当前API

**config.py**：

```python
# GET /config 返回
{
  "ai_provider": "opencode",
  "ai_model": "",  # ← 当前配置文件没有这个字段！
  ...
}

# GET /config/models 返回
{
  "default_provider": "opencode",
  "models": [
    {
      "id": "opencode-minimax-m2.5-free",  # ← 格式: "provider-modelname"
      "name": "minimax-m2.5-free",
      "provider": "opencode"
    },
    ...
  ]
}
```

### 1.3 配置文件当前结构

```yaml
ai:
  provider: opencode        # ← 只有这个，没有 ai.model
  opencode:
    models:
      - minimax-m2.5-free
      - glm-5-free
      - kimi-k2.5-free
```

---

## 二、问题根本原因

### 2.1 配置文件缺少 `ai.model`

**现状**：
- 配置文件只有 `ai.provider: opencode`
- 没有 `ai.model` 字段
- 后端 `getConfig()` 返回的 `ai_model` 是空字符串

**导致的问题**：

```
用户选择 "OpenCode (kimi-k2.5-free)"
  ↓
前端更新：_currentModelInfo = "opencode-kimi-k2.5-free"
  ↓
前端调用 updateConfig，但只传了 ai_provider
  ↓
后端只更新 config['ai']['provider'] = "opencode"
  ↓
后端读取模型：config['ai']['opencode']['model'] = "glm-5-free"（默认）
  ↓
用户以为用了 kimi-k2.5-free，但后端不知道！
```

### 2.2 前后端数据不一致

| 位置 | 当前模型 | 格式 |
|------|---------|------|
| 前端状态 | `"opencode-kimi-k2.5-free"` | `"provider-modelname"` |
| 后端读取 | `""`（空字符串） | 无 |
| 配置文件 | 无 | 缺少 ai.model |

---

## 三、设计方案（保持现有使用方式）

### 3.1 配置文件修改

**增加顶层 `ai.model` 字段**：

```yaml
ai:
  provider: opencode        # 当前provider
  model: kimi-k2.5-free   # 【新增】当前使用的模型
  opencode:
    models:                 # 该provider的可用模型列表
      - minimax-m2.5-free
      - glm-5-free
      - kimi-k2.5-free
```

### 3.2 后端API设计

#### 3.2.1 getConfig - 返回 ai.model

```python
@router.get("/config", response_model=ConfigResponse)
async def get_system_config():
    config = get_config_instance()
    ai_config = config.get("ai", {})
    
    provider = ai_config.get('provider', 'zhipuai')
    
    # 【新增】读取顶层 ai.model
    model = ai_config.get('model', ai_config.get(f'{provider}.model', ''))
    
    return ConfigResponse(
        ai_provider=provider,
        ai_model=model,  # 【新增】
        ...
    )
```

#### 3.2.2 updateConfig - 同时更新 provider 和 model

```python
@router.put("/config")
async def update_config(config_update: ConfigUpdate):
    config_path = _get_config_path()
    
    with open(config_path, 'r+', encoding='utf-8') as f:
        config_data = yaml.safe_load(f) or {}
    
    # 更新 ai.provider
    if config_update.ai_provider:
        config_data['ai']['provider'] = config_update.ai_provider
    
    # 【新增】更新 ai.model
    if config_update.ai_model:
        config_data['ai']['model'] = config_update.ai_model
    
    # 可选：同时更新provider下的默认model
    if config_update.ai_provider and config_update.ai_model:
        provider = config_update.ai_provider
        if 'ai' in config_data and provider in config_data['ai']:
            config_data['ai'][provider]['model'] = config_update.ai_model
    
    # 写回配置文件
    with open(config_path, 'w', encoding='utf-8') as f:
        yaml.dump(config_data, f, allow_unicode=True, default_flow_style=False)
    
    # 重新加载
    config = get_config_instance()
    config.reload()
    
    return {"success": True, ...}
```

#### 3.2.3 get_model_list - 增加 current_model标记

```python
class ModelInfo(BaseModel):
    """模型信息"""
    id: int = Field(..., description="模型ID序号")
    provider: str = Field(..., description="提供商名称(小写)")
    model: str = Field(..., description="模型名称")
    display_name: str = Field(..., description="显示名称，格式: Provider (model)")
    current_model: bool = Field(default=False, description="是否为当前模型")  # 【新增】

@router.get("/config/models", response_model=ModelListResponse)
async def get_model_list():
    config = get_config_instance()
    ai_config = config.get("ai", {})
    
    # 【新增】读取当前模型
    current_provider = ai_config.get("provider", "")
    current_model = ai_config.get("model", "")  # 【新增】
    
    models = []
    model_id = 1
    
    # 按照配置文件中的provider顺序构建模型列表
    for provider in SUPPORTED_PROVIDERS:
        provider_config = ai_config.get(provider, {})
        models_list = provider_config.get("models", [])
        
        if isinstance(models_list, list) and models_list:
            for model_name in models_list:
                display_name = f"{provider_display_names.get(provider, provider)} ({model_name})"
                
                models.append(ModelInfo(
                    id=model_id,
                    provider=provider,
                    model=model_name,
                    display_name=display_name,
                    current_model=(  # 【新增】标记当前模型
                        provider == current_provider and 
                        model_name == current_model
                ))
                model_id += 1
    
    return ModelListResponse(
        models=models,
        default_provider=ai_config.get("provider", "")
    )
```

### 3.3 后端AI对话处理设计

#### 3.3.1 chat_stream - 从配置文件读取模型

**核心原则**：AI对话中使用的模型信息，**必须**从配置文件读取，而不是从前端请求中获取。

```python
async def chat_stream(request: ChatRequest):
    task_id = str(uuid.uuid4())
    
    async def generate():
        # 【设计】AI对话必须从配置文件读取模型信息
        # 这样确保：
        # 1. 用户切换模型后，AI对话使用新模型
        # 2. 下次启动时，自动使用上次保存的模型
        # 3. 前后端模型完全一致
        ai_service = AIServiceFactory.get_service()
        
        # 获取display_name用于显示
        display_name = f"{PROVIDER_DISPLAY_NAMES[ai_service.provider]} ({ai_service.model})"
        
        yield f"data: {json.dumps({'type': 'start', 'display_name': display_name})}\n\n"
        
        # ... 其他逻辑保持不变 ...
        
        yield f"data: {json.dumps({'type': 'final', 'display_name': display_name})}\n\n"
    
    return StreamingResponse(generate())
```

---

## 四、完整流程

### 4.1 初始化流程

```
前端启动
  ↓
显示状态："未配置"（如果是第一次启动或配置无效）
  ↓
调用 GET /config/models 和 GET /config
  ↓
后端返回：
  - models: [{id: "opencode-minimax-m2.5-free", ...}]
  - ai_provider: "opencode"
  - ai_model: "kimi-k2.5-free"  # 【现在从顶层读取】
  ↓
前端匹配：
  - 找到 m.id 包含 "kimi-k2.5-free" 且 provider = "opencode"
  - 设置 _currentModelInfo = "opencode-kimi-k2.5-free"
  ↓
自动调用"检查服务"（GET /chat/validate）
  ↓
根据验证结果显示模型状态：
  - 成功（绿色）：正常可用
  - 警告（黄色）：限速/欠费
  - 错误（红色）：不可用
  ↓
界面显示当前模型及可用状态
```

### 4.2 切换模型流程

```
用户选择 "OpenCode (kimi-k2.5-free)"
  ↓
前端解析：provider="opencode", model="kimi-k2.5-free"
  ↓
调用 PUT /config {
  ai_provider: "opencode",
  ai_model: "kimi-k2.5-free"  # 【新增】
}
  ↓
后端更新 config.yaml：
  - ai.provider = "opencode"
  - ai.model = "kimi-k2.5-free"  # 【新增】
  - ai.opencode.model = "kimi-k2.5-free"  # 可选
  ↓
前端更新状态：
  - _currentModelInfo = "opencode-kimi-k2.5-free"
  ↓
界面显示当前模型
```

### 4.3 发送消息流程

```
用户输入消息
  ↓
前端发送 POST /chat {
  messages: [...],
  stream: false
}
  ↓
后端处理请求：
  - 从配置文件读取 ai.provider + ai.model 创建AI服务
  - 【重要】AI对话必须使用配置文件中的模型，不能使用前端传递的模型
  - 这是为了保证：下次启动时自动使用上次保存的模型
  ↓
后端返回响应：
  - "display_name": "OpenCode (kimi-k2.5-free)"  # 从配置文件读取
  - 包含：完整的provider和model信息
  ↓
前端记录到对话历史，显示模型名称
```

### 4.4 保存和使用当前模型

```
客户端退出时，web退出后要保存最后一次选择的可用模型
  ↓
配置文件中的ai.provider + ai.model已经自动保存
  ↓
下一次启动时：
  - 从配置文件读取ai.provider + ai.model
  - 使用上次最后可用的模型进行检查服务
  - 显示这个模型的可用状态信息
```

