### 8.6 前端调用示例

#### 8.6.1 获取配置和模型列表

```typescript
// 初始化时调用
const [modelData, config] = await Promise.all([
  configApi.getModelList(),  // GET /api/v1/config/models
  configApi.getConfig()       // GET /api/v1/config
]);

// config.ai_model 现在有值
console.log(config.ai_model); // "kimi-k2.5-free"
```

#### 8.6.2 切换模型

```typescript
const handleSwitch = async (modelId: string) => {
  const model = modelList.find(m => m.id === modelId);
  if (!model) return;
  
  // 解析 provider 和 model
  const [provider, modelName] = modelId.split('-');
  
  // 同时更新 ai_provider 和 ai_model
  await configApi.updateConfig({
    ai_provider: provider,
    ai_model: modelName
  });
  
  // 检查服务
  await chatApi.validateService();
};
```

#### 8.6.3 检查服务

```typescript
// 手动检查或自动检查
const checkService = async () => {
  const result = await chatApi.validateService();
  
  if (result.success) {
    // 绿色显示
    setServiceStatus('success');
  } else if (result.message.includes('限速') || result.message.includes('欠费')) {
    // 黄色显示
    setServiceStatus('warning');
  } else {
    // 红色显示
    setServiceStatus('error');
  }
};
```

