# OmniAgentAs-desk 配置文件模板
# 使用说明：
# 1. 复制此文件为 config.yaml
# 2. 填入您的API密钥
# 3.  config.yaml 已被Git忽略，不会提交到仓库

ai:
  # ✅ 顶层配置（全局）
  model: kimi-k2.5-free
  provider: opencode  # ✅ 当前Provider

  # ✅ Provider配置（多个）
  opencode:
    api_base: https://opencode.ai/zen/v1
    api_key: sk_xxx...
    models:
      - minimax-m2.5-free
      - kimi-k2.5-free
      timeout: 120

  longcat:
    api_base: https://api.longcat.chat/openai/v1
    api_key: ak_xxx...
    models:
      - LongCat-Flash-Thinking
      - LongCat-Flash-Thinking
      timeout: 120

  zhipuai:
    api_base: https://test.com
    api_key: test123
    max_retries: 3
    models:
      - glm-4.7-flash
      - cogview-3-flash
      timeout: 90

# 文件操作配置
file_operations:
  # 工作目录（文件操作的根目录）
  workspace_dir: "./workspace"
  # 是否启用安全模式（禁止删除操作）
  safe_mode: true
  # 最大文件大小（MB）
  max_file_size: 10

# 日志配置
logging:
  level: INFO  # DEBUG, INFO, WARNING, ERROR
  file: logs/app.log
  max_size: 10MB
  backup_count: 5
